# ============================================================
# .dockerignore — Prevent sensitive and unnecessary files
# from being included in the Docker build context
# ============================================================

# Version control
.git
.gitignore

# Python artifacts
__pycache__
*.py[cod]
*.pyo
.pytest_cache
.coverage
htmlcov/
.tox
*.egg-info
dist/
build/

# Virtual environments
.venv
venv
env

# Environment files (may contain secrets!)
.env
.env.*
*.pem
*.key

# IDE files
.vscode
.idea
*.swp

# Documentation (not needed in container)
docs/
*.md
LICENSE

# CI/CD configs (not needed in container)
.github/

# Terraform (not needed in container)
terraform/

# Docker files (prevent recursive inclusion)
Dockerfile
docker-compose*.yml
.dockerignore

# Monitoring configs (separate containers)
monitoring/
nginx/

# Policy files (used in CI, not runtime)
policy/

# Tests (not needed in production image)
tests/
